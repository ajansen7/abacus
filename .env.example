# --- Abacus platform ---------------------------------------------------------
# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# HTTP server
ABACUS_HOST=127.0.0.1
ABACUS_PORT=3001

# Where tmux logs, OTel exports, and per-task working dirs land
ABACUS_RUNTIME_DIR=./runtime

# Watchdog caps (platform-wide defaults; products can tighten per-task)
ABACUS_WATCHDOG_WALLCLOCK_SECONDS=600
ABACUS_WATCHDOG_MAX_ITERATIONS=40
ABACUS_WATCHDOG_MAX_TOKENS=500000

# Per-product `state` shim subprocess timeout. Cold tsx startup can run multiple
# seconds; default 30s leaves headroom under concurrent dashboard refetches.
ABACUS_STATE_SHIM_TIMEOUT_MS=30000

# Beads / Dolt data directory (Beads manages this)
BEADS_DATA_DIR=./.beads

# OpenTelemetry (OTLP HTTP). Leave blank to disable export.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=abacus

# --- Product: Marathon -------------------------------------------------------
# Strava OAuth app credentials (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Long-lived refresh token for the authorizing Strava user. Obtained by
# running `pnpm --filter @abacus-products/marathon exec tsx scripts/strava-onboard.ts`.
STRAVA_REFRESH_TOKEN=

# Shared secret echoed during webhook subscription handshake
STRAVA_VERIFY_TOKEN=change-me-to-a-random-string

# Optional IP allowlist for Strava webhook POSTs (comma-separated CIDRs)
STRAVA_ALLOWED_IPS=

# Skip live Strava API calls in fetch-and-store-strava.ts; useful for tests
STRAVA_OFFLINE=0
